# Copy to .env for local dev / hosted builds.

# Hosted multiplayer room server for static builds (GitHub Pages, etc.).
# Local dev usually leaves this blank and connects directly to VITE_MP_PORT.
VITE_MP_URL=wss://your-room-server.example.com

# Local room-server port used by ?mp=1 on localhost.
VITE_MP_PORT=8787

# WebRTC voice — STUN/TURN. Public STUN is fine for dev; TURN needed for prod NAT traversal.
VITE_STUN_URL=stun:stun.l.google.com:19302
