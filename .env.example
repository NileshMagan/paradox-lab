# Copy to .env for local dev. Used later when the networking layer lands.

# Signalling / game server (WebSocket). Not required for single-client dev.
VITE_SERVER_URL=ws://localhost:8080

# WebRTC voice — STUN/TURN. Public STUN is fine for dev; TURN needed for prod NAT traversal.
VITE_STUN_URL=stun:stun.l.google.com:19302
